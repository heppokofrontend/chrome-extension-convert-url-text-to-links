{
  "manifest_version": 3,
  "minimum_chrome_version": "120",
  "name": "__MSG_extName__",
  "version": "1.1.0",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "action": {
    "default_icon": "images/icon-128.png",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content_scripts.js"]
    }
  ],
  "icons": {
    "128": "images/icon-128.png"
  },
  "permissions": ["storage"]
}
